# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# Flask
SECRET_KEY=replace_with_a_long_random_string_at_least_32_chars
FLASK_ENV=production

# Database
DB_HOST=db
DB_NAME=taskdb
DB_USER=taskuser
DB_PASSWORD=replace_with_strong_password
DB_ROOT_PASSWORD=replace_with_strong_root_password

# OpenWeatherMap API (free tier: https://openweathermap.org/api)
OPENWEATHER_API_KEY=replace_with_your_api_key
